{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "760px",
      "wideSize": "1280px"
    },
    "color": {
      "palette": [
        {
          "slug": "canvas",
          "name": "Canvas",
          "color": "#f8f2e9"
        },
        {
          "slug": "paper",
          "name": "Paper",
          "color": "#fffaf4"
        },
        {
          "slug": "ink",
          "name": "Ink",
          "color": "#15110f"
        },
        {
          "slug": "muted",
          "name": "Muted",
          "color": "#665c50"
        },
        {
          "slug": "accent",
          "name": "Accent",
          "color": "#6113af"
        },
        {
          "slug": "gold",
          "name": "Gold",
          "color": "#b38a55"
        }
      ]
    },
    "spacing": {
      "units": [
        "px",
        "rem",
        "%",
        "vw"
      ],
      "spacingSizes": [
        {
          "slug": "xs",
          "name": "XS",
          "size": "0.75rem"
        },
        {
          "slug": "sm",
          "name": "SM",
          "size": "1rem"
        },
        {
          "slug": "md",
          "name": "MD",
          "size": "1.5rem"
        },
        {
          "slug": "lg",
          "name": "LG",
          "size": "2.25rem"
        },
        {
          "slug": "xl",
          "name": "XL",
          "size": "3.5rem"
        }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "slug": "manrope",
          "name": "Manrope",
          "fontFamily": "\"Manrope\", sans-serif"
        },
        {
          "slug": "dm-serif",
          "name": "DM Serif Display",
          "fontFamily": "\"DM Serif Display\", serif"
        }
      ],
      "fontSizes": [
        {
          "slug": "body",
          "name": "Body",
          "size": "1rem"
        },
        {
          "slug": "body-large",
          "name": "Large Body",
          "size": "1.125rem"
        },
        {
          "slug": "heading",
          "name": "Heading",
          "size": "2.25rem"
        },
        {
          "slug": "display",
          "name": "Display",
          "size": "4rem"
        }
      ]
    },
    "blocks": {
      "core/button": {
        "border": {
          "radius": "999px"
        }
      }
    }
  },
  "styles": {
    "color": {
      "background": "#fcf7f0",
      "text": "#15110f"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--manrope)",
      "lineHeight": "1.72"
    },
    "elements": {
      "heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--dm-serif)",
          "fontWeight": "400",
          "letterSpacing": "-0.03em"
        }
      },
      "link": {
        "color": {
          "text": "#6113af"
        }
      }
    }
  }
}
